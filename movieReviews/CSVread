import pandas as pd

df = pd.read_csv(r"C:\Users\vesel\OneDrive\Plocha\Honza\NLP\miniprojekt\movie_reviews.csv")

df.shape
df.columns
df.info()
df.isnull().sum()
df.duplicated().sum()

# Remove duplicates
df = df.drop_duplicates()

# Filling missing text fields with empty strings - zatím nerozumím zadání
text_columns = df.select_dtypes(include=["object"]).columns
df[text_columns] = df[text_columns].fillna("")

# Converting dates using pd.to_datetime()
df["review_date"] = pd.to_datetime(df["review_date"], errors="coerce")
df["publish_date"] = pd.to_datetime(df["publish_date"], errors="coerce")

# Trimming whitespace in text fields
for col in text_columns:
    df[col] = df[col].astype(str).str.strip()

# Ensuring numeric fields (e.g., rating) have correct data types
numeric_cols = ["rating", "review_length", "word_count", "sentiment_score", "views"]

for col in numeric_cols:
    df[col] = pd.to_numeric(df[col], errors="coerce")


